%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5a3a40b1ee4441518f69c26c62cb3cde, type: 3}
  m_Name: Elder_FirstVillage
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  dialogueId: Elder_FirstVillage
  lines:
  - speakerProfile: {fileID: 11400000, guid: dce1613e54865ac40a2484729a4966fc, type: 2}
    speakerName: "Elder"
    text: "What was defiled by force cannot be returned by force. If we send a warrior after the fire, he will carry pride with him. If we send a rich man, he will think of the price. If we send someone whose heart is full of anger, Umay will not hear his plea."
    portrait: {fileID: 21300000, guid: 4b5ded42dff2f0e49ae77db6484d10f3, type: 3}
  - speakerProfile: {fileID: 11400000, guid: dce1613e54865ac40a2484729a4966fc, type: 2}
    speakerName: "Elder"
    text: "We must seek not the strongest, and not the most noble. We must find one whose thoughts are pure as spring water, and whose heart cannot rejoice in another's suffering."
    portrait: {fileID: 21300000, guid: 4b5ded42dff2f0e49ae77db6484d10f3, type: 3}
  - speakerProfile: {fileID: 11400000, guid: dce1613e54865ac40a2484729a4966fc, type: 2}
    speakerName: "Elder"
    text: "Aisulu."
    portrait: {fileID: 21300000, guid: 4b5ded42dff2f0e49ae77db6484d10f3, type: 3}
  - speakerProfile: {fileID: 11400000, guid: 6992f1ad55b7805439d6200abb695e15, type: 2}
    speakerName: "Aisulu"
    text: "I am here, Elder. Why do you call me?"
    portrait: {fileID: 21300000, guid: 39e15864a50fa1c4098c5a8759a13577, type: 3}
  - speakerProfile: {fileID: 11400000, guid: dce1613e54865ac40a2484729a4966fc, type: 2}
    speakerName: "Elder"
    text: "I have seen you share your last bread with a child who was not of your family. I have seen you speak gently to those who answered you with harshness. I have seen you refuse to pass by the weak, and never laugh at another's mistake."
    portrait: {fileID: 21300000, guid: 4b5ded42dff2f0e49ae77db6484d10f3, type: 3}
  - speakerProfile: {fileID: 11400000, guid: dce1613e54865ac40a2484729a4966fc, type: 2}
    speakerName: "Elder"
    text: "Sometimes it is not a strong hand that opens the way, but a heart in which there is no darkness. Umay took the fire not from our bodies, but from our souls. So the one who asks for it must be a soul that has not yet forgotten the light."
    portrait: {fileID: 21300000, guid: 4b5ded42dff2f0e49ae77db6484d10f3, type: 3}
  - speakerProfile: {fileID: 11400000, guid: 6992f1ad55b7805439d6200abb695e15, type: 2}
    speakerName: "Aisulu"
    text: "You want me to go to Umay?"
    portrait: {fileID: 21300000, guid: 39e15864a50fa1c4098c5a8759a13577, type: 3}
  - speakerProfile: {fileID: 11400000, guid: dce1613e54865ac40a2484729a4966fc, type: 2}
    speakerName: "Elder"
    text: "I do not command you, Aisulu. The road to a goddess must not begin with another's will. I call you because I believe: if anyone can hear Umay, it is one who knows how to listen to people, to the earth, and to her own heart."
    portrait: {fileID: 21300000, guid: 4b5ded42dff2f0e49ae77db6484d10f3, type: 3}
  - speakerProfile: {fileID: 11400000, guid: dce1613e54865ac40a2484729a4966fc, type: 2}
    speakerName: "Elder"
    text: "If you are ready, my child, set out now. If you find even a single spark, do not think it small, because sometimes the return of a whole sun begins with a small spark."
    portrait: {fileID: 21300000, guid: 4b5ded42dff2f0e49ae77db6484d10f3, type: 3}
